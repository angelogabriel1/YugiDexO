PORT=3000
HOST=0.0.0.0
PUBLIC_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require
NEON_AUTH_URL=https://ep-exemplo.neonauth.regiao.aws.neon.tech/neondb/auth
R2_PUBLIC_URL=https://cartas.seudominio.com
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=yugidex-cards
R2_ACCESS_KEY_ID=sua-access-key
R2_SECRET_ACCESS_KEY=sua-secret-key
# Opcionais: use somente durante a migracao dos dados legados.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role
BRL_USD_RATE=5.50
MYPCARDS_BASE_URL=https://mypcards.com
REQUEST_TIMEOUT_MS=8000
# Opcional: mostra botao de compra/oferta nos detalhes das cartas.
# Placeholders aceitos: {cardId}, {id}, {card_id}, {name}, {encodedName}, {query}
AFFILIATE_CARD_URL_TEMPLATE=https://sua-loja.example/busca?q={encodedName}&ref=SEU_CODIGO
AFFILIATE_LINK_LABEL=Ver oferta da carta
AFFILIATE_DISCLOSURE=Link de afiliado: podemos receber comissão sem custo extra para você.
